# ============ Embedding 配置 ============
# Provider 类型: openai（OpenAI 兼容）
EMBEDDING_PROVIDER=openai

# OpenAI 兼容配置（使用 Gitee AI）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://ai.gitee.com/v1
OPENAI_MODEL=Qwen3-Embedding-0.6B
OPENAI_DIMENSIONS=1024

# ============ 数据库配置 ============
# 数据目录（相对于 skill-router 根目录）
DATA_DIR=./data

# ============ 检索配置 ============
DEFAULT_TOP_K=5
MIN_SCORE_THRESHOLD=0.3

# ============ Cisco Skill Scanner - 安全扫描配置 ============
# 仅在使用深度扫描时需要

# LLM Provider: anthropic | openai | azure-openai | azure-ai | aws-bedrock | gcp-vertex | ollama | openrouter
SKILL_SCANNER_LLM_PROVIDER=anthropic

# API Key（深度扫描必填）
SKILL_SCANNER_LLM_API_KEY=

# 模型名称
# anthropic 默认: claude-3-5-sonnet-20241022
# openai 默认: gpt-4o
# azure-openai 默认: azure/gpt-4o
SKILL_SCANNER_LLM_MODEL=claude-3-5-sonnet-20241022

# 自定义 API 端点（可选，用于代理或自定义 LLM 服务）
SKILL_SCANNER_LLM_BASE_URL=

# API 版本（仅 Azure 需要）
SKILL_SCANNER_LLM_API_VERSION=

# AWS Bedrock 配置（仅 provider=aws-bedrock 时需要）
SKILL_SCANNER_AWS_REGION=us-east-1
SKILL_SCANNER_AWS_PROFILE=
SKILL_SCANNER_AWS_SESSION_TOKEN=
